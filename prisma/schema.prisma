// GeoBridge - Database Schema for Supabase
// This schema is designed for PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Users table - managed by Supabase Auth
// We create a profile table linked to auth.users
model Profile {
  id        String   @id @default(uuid())
  email     String   @unique
  full_name String?
  avatar_url String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  
  searches  Search[]
  
  @@map("profiles")
}

// Saved searches/areas
model Search {
  id          String   @id @default(uuid())
  user_id     String
  title       String
  description String?
  
  // Search parameters
  address     String?
  latitude    Float?
  longitude   Float?
  
  // Drawn area (GeoJSON)
  area_geojson String?  // JSON string of the drawn polygon/rectangle
  
  // Search filters
  filters     String?  // JSON string of additional filters
  
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  
  user        Profile  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  @@map("searches")
}

// Analysis results (from satellite data)
model Analysis {
  id          String   @id @default(uuid())
  search_id   String?
  user_id     String
  
  // Area info
  area_name   String?
  bbox        String   // JSON: {minLon, minLat, maxLon, maxLat}
  
  // Analysis parameters
  start_date  DateTime
  end_date    DateTime
  interval_months Int @default(6)
  
  // Results
  status      String   @default("pending") // pending, processing, completed, failed
  results     String?  // JSON string of analysis results
  risk_score  Float?
  
  created_at  DateTime @default(now())
  completed_at DateTime?
  
  @@map("analyses")
}

// API Keys per l'accesso all'API pubblica
model ApiKey {
  id           String   @id @default(uuid())
  key          String   @unique  // SHA-256 hash della chiave
  name         String
  permissions  String   @default("read")  // read | write
  active       Boolean  @default(true)
  lastUsedAt   DateTime?
  requestCount Int      @default(0)
  createdAt    DateTime @default(now())

  @@map("api_keys")
}
